{
	"name": "@pretendonetwork/nintendo-files",
	"version": "1.1.1",
	"description": "TypeScript library for interacting with several Nintendo file formats across various consoles.",
	"type": "commonjs",
	"scripts": {
		"lint": "eslint ./src",
		"clean": "npx rimraf ./dist",
		"build": "npm run lint && npm run clean && tsc && tsc-alias"
	},
	"keywords": [],
	"author": "",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/PretendoNetwork/nintendo-file-formats.git"
	},
	"license": "LGPL-3.0-only",
	"devDependencies": {
		"@pretendonetwork/eslint-config": "^0.1.4",
		"@types/node": "^25.5.0",
		"@types/node-rsa": "^1.1.1",
		"eslint": "^9.39.4",
		"rimraf": "^5.0.1",
		"tsc-alias": "^1.8.7",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"image-encode": "^1.3.1",
		"node-rsa": "^1.1.1"
	},
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./byaml": {
			"types": "./dist/byaml.d.ts",
			"default": "./dist/byaml.js"
		},
		"./byml": {
			"types": "./dist/byaml.d.ts",
			"default": "./dist/byaml.js"
		},
		"./certificate": {
			"types": "./dist/certificate.d.ts",
			"default": "./dist/certificate.js"
		},
		"./cia": {
			"types": "./dist/cia.d.ts",
			"default": "./dist/cia.js"
		},
		"./compression/cmp": {
			"types": "./dist/compression/cmp.d.ts",
			"default": "./dist/compression/cmp.js"
		},
		"./compression/yaz0": {
			"types": "./dist/compression/yaz0.d.ts",
			"default": "./dist/compression/yaz0.js"
		},
		"./msbt": {
			"types": "./dist/msbt.d.ts",
			"default": "./dist/msbt.js"
		},
		"./me01": {
			"types": "./dist/me01.d.ts",
			"default": "./dist/me01.js"
		},
		"./smdh": {
			"types": "./dist/smdh.d.ts",
			"default": "./dist/smdh.js"
		},
		"./ticket": {
			"types": "./dist/ticket.d.ts",
			"default": "./dist/ticket.js"
		},
		"./tmd": {
			"types": "./dist/tmd.d.ts",
			"default": "./dist/tmd.js"
		}
	}
}
