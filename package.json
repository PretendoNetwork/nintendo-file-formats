	"scripts": {
		"lint": "eslint ./src",
		"clean": "npx rimraf ./dist",
		"build": "npm run lint && npm run clean && tsdown",
		"test": "npx vitest run"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/PretendoNetwork/nintendo-file-formats.git"
	},
	"license": "LGPL-3.0-only",
	"main": "./dist/index.cjs",
